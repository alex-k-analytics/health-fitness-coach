{
  "name": "health-fitness-coach-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "ios:sync": "npm run build && cap sync ios",
    "ios:open": "cap open ios",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "ux:audit": "playwright test --config=playwright.ux.config.ts",
    "ux:audit:headed": "playwright test --config=playwright.ux.config.ts --headed",
    "ux:audit:install": "playwright install chromium",
    "ux:inspect": "playwright-cli -s=health-fitness-coach open http://localhost:5173 --headed",
    "ux:inspect:mobile": "playwright-cli -s=health-fitness-coach resize 375 812",
    "ux:inspect:tablet": "playwright-cli -s=health-fitness-coach resize 768 1024",
    "ux:inspect:desktop": "playwright-cli -s=health-fitness-coach resize 1440 900",
    "ux:inspect:screenshot": "playwright-cli -s=health-fitness-coach screenshot --full-page --filename=../docs/ux-audit-screenshots/cli-inspection.png",
    "ux:inspect:show": "playwright-cli show",
    "ux:inspect:close": "playwright-cli -s=health-fitness-coach close",
    "ux:inspect:install": "playwright-cli install-browser chromium",
    "ux:inspect:help": "playwright-cli --help"
  },
  "dependencies": {
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-router": "^1.168.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "vaul": "^1.1.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/cli": "^0.1.13",
    "@playwright/test": "^1.59.1",
    "@tanstack/router-devtools": "^1.166.13",
    "@tanstack/router-plugin": "^1.167.27",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
