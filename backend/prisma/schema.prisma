generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MealAnalysisStatus {
  PENDING
  COMPLETED
  FALLBACK
  FAILED
}

enum MealImageKind {
  PLATE
  LABEL
  OTHER
}

model Account {
  id               String         @id @default(cuid())
  email            String         @unique
  passwordHash     String
  displayName      String
  goalSummary      String?
  calorieGoal      Int?
  proteinGoalGrams Float?
  carbGoalGrams    Float?
  fatGoalGrams     Float?
  heightCm         Float?
  activityLevel    String?
  notes            String?
  healthMetrics    HealthMetric[]
  savedFoods       SavedFood[]
  meals            MealEntry[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model HealthMetric {
  id                     String   @id @default(cuid())
  accountId              String
  recordedAt             DateTime @default(now())
  weightKg               Float?
  systolicBloodPressure  Int?
  diastolicBloodPressure Int?
  restingHeartRate       Int?
  bodyFatPercent         Float?
  waistCm                Float?
  note                   String?
  account                Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt              DateTime @default(now())

  @@index([accountId, recordedAt(sort: Desc)])
}

model SavedFood {
  id                 String      @id @default(cuid())
  accountId          String
  name               String
  brand              String?
  servingDescription String?
  servingWeightGrams Float?
  calories           Float?
  proteinGrams       Float?
  carbsGrams         Float?
  fatGrams           Float?
  fiberGrams         Float?
  sugarGrams         Float?
  sodiumMg           Float?
  micronutrients     Json?
  notes              String?
  account            Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  meals              MealEntry[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([accountId, name])
}

model MealEntry {
  id                 String             @id @default(cuid())
  accountId          String
  savedFoodId        String?
  title              String
  notes              String?
  eatenAt            DateTime
  servingDescription String?
  quantity           Float?
  weightGrams        Float?
  analysisStatus     MealAnalysisStatus @default(PENDING)
  analysisSummary    String?
  confidenceScore    Float?
  estimatedCalories  Float?
  proteinGrams       Float?
  carbsGrams         Float?
  fatGrams           Float?
  fiberGrams         Float?
  sugarGrams         Float?
  sodiumMg           Float?
  micronutrients     Json?
  vitamins           Json?
  assumptions        Json?
  foodBreakdown      Json?
  rawAnalysis        Json?
  aiModel            String?
  account            Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  savedFood          SavedFood?         @relation(fields: [savedFoodId], references: [id], onDelete: SetNull)
  images             MealImage[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([accountId, eatenAt(sort: Desc)])
}

model MealImage {
  id               String        @id @default(cuid())
  mealEntryId      String
  storageKey       String
  originalFileName String
  contentType      String
  sizeBytes        Int
  kind             MealImageKind @default(OTHER)
  mealEntry        MealEntry     @relation(fields: [mealEntryId], references: [id], onDelete: Cascade)
  createdAt        DateTime      @default(now())

  @@index([mealEntryId])
}
